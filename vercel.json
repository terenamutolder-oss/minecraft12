{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd minecraft-web-client-next/minecraft-web-client-next && corepack enable && corepack prepare pnpm@10.32.1 --activate && pnpm install",
  "buildCommand": "cd minecraft-web-client-next/minecraft-web-client-next && pnpm run build",
  "outputDirectory": "minecraft-web-client-next/minecraft-web-client-next/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ]
}
