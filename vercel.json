{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "cd minecraft-web-client-next/minecraft-web-client-next && export CI=true VERCEL=1 && npx --yes pnpm@10.32.1 install && npx --yes pnpm@10.32.1 run build",
  "outputDirectory": "minecraft-web-client-next/minecraft-web-client-next/dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "same-origin"
        }
      ]
    }
  ]
}
